rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /jobs/{jobId} {
      allow read, write: if request.auth != null;
    }

    match /racquets/{racquetId} {
      allow read, write: if request.auth != null;
    }

    match /shops/{shopId} {
      allow read, write: if request.auth != null;
    }

    match /alerts/{alertId} {
      allow read, write: if request.auth != null;
    }
  }
}
